{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "crons": [
        {
            "path": "/api/cron/lurah-ekosistem",
            "schedule": "0 0 * * *"
        }
    ]
}