# ============================================
# .gitignore — Clean Tree Mandate (gemini.md Protocol)
# RULES: Only tracked if it's: source code, config, or essential deployment scripts.
# ============================================

# === DEPENDENCIES ===
node_modules/

# === ENVIRONMENT VARIABLES (SECRET — NEVER COMMIT) ===
.env
.env.local
.env.*
.env*.local
.env.vercel
.env.vercel.prod

# === BUILD & COMPILE OUTPUTS ===
dist/
artifacts/
cache/
typechain-types/
coverage/
coverage.json
stats.html

# === HARDHAT ===
hardhat.config.js.backup

# === IDE & EDITOR CONFIGS (Local only) ===
.vscode/
.idea/
.cursorrules
.gemini/
.DS_Store

# === AGENT LOCAL/PRIVATE CONFIG (Track scripts, not secrets) ===
.agents/**/credentials*
.agents/**/secrets*
.agents/**/*.key
.agents/**/.env*

# === VERCEL LOCAL STATE ===
.vercel/

# === LOGS (Never commit logs) ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === VITE TEMP FILES ===
*.timestamp-*.mjs

# === TEMPORARY & SCRATCH FILES (gemini.md: Clean Tree Mandate) ===
# Any file prefixed with tmp_ is considered a transient scratch file.
tmp/
tools/nexus-monitor/
tmp_*.cjs
tmp_*.js
tmp_*.mjs
tmp_*.ts
*.tmp
*.scratch.*

# === LEGACY & ARCHIVE FOLDERS (Source of truth is /contracts, not archives) ===
# _archive/ folder contains old contract versions - not needed in clean tree
_archive/

# === LARGE COMPILED FLAT SOLIDITY FILES (Generated — Rebuild via `npx hardhat flatten`) ===
FlatCryptoDisco.sol
FlatCryptoDisco_utf8.sol

# === VERIFICATION REPORTS & COMPARISON REPORTS (CI artifacts, not source) ===
scripts/env-comparison-report-*.txt
scripts/env-comparison-report.txt
scripts/env-sync-report-*.txt

# === TEST ENVIRONMENT TEMP DIR ===
test-env/

# === SUPABASE TEMP ===
Raffle_Frontend/supabase/.temp/

# === OTHER VERCEL PROJECTS ===
verification_vault/

# === DATA DUMP & LOGS HYGIENE (Mandatory) ===
supabase_full_dump.json
*.sql.dump
full_supabase_dump.sql
nexus-activity.json
nexus-bridge.json

# === MEDIA & SCREENSHOTS (MANDATORY — Section 27) ===
# No agent-generated media or browser snapshots allowed in repo.
browser_recordings/
**/browser/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.mp4
*.mov
artifacts/*.png

# === SECURITY CERTIFICATES & PRIVATE KEYS ===
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt

# === OS & EDITOR GARBAGE ===
.DS_Store
Thumbs.db
desktop.ini
*.bak
*.old

# === GENERATED ARTIFACTS & EXTRACTED DATA ===
abi_extracted.json
DailyApp.V.12/
NFT_Raffle_Source/
.vercel
