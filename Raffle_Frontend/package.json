{
  "name": "nft-raffle-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx,ts,tsx --report-unused-disable-directives",
    "check-routes": "node scripts/check-api-routes.cjs",
    "check-abi": "node scripts/check-abi-parity.cjs",
    "check-live-abi": "node scripts/check-live-abi-selectors.cjs --chain base-sepolia",
    "check-live-rls": "node scripts/check-live-rls.cjs",
    "audit-checks": "npm run check-routes && npm run check-abi",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@base-org/account": "2.5.3",
    "@coinbase/onchainkit": "1.1.2",
    "@farcaster/miniapp-sdk": "0.1.10",
    "@lifi/sdk": "3.16.3",
    "@neynar/nodejs-sdk": "3.134.0",
    "@rainbow-me/rainbowkit": "2.2.10",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "2.99.1",
    "@tanstack/react-query": "5.90.20",
    "axios": "^1.16.1",
    "buffer": "6.0.3",
    "ethers": "6.16.0",
    "lucide-react": "0.356.0",
    "pinata-web3": "0.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "2.6.0",
    "react-router-dom": "6.30.3",
    "swr": "2.4.0",
    "viem": "2.47.4",
    "wagmi": "2.19.5",
    "zustand": "4.5.7"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vercel/node": "5.7.16",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.4.24",
    "cross-env": "10.1.0",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.26",
    "patch-package": "8.0.1",
    "postcss": "8.5.6",
    "postinstall-postinstall": "2.1.0",
    "rollup-plugin-visualizer": "6.0.5",
    "tailwindcss": "3.4.19",
    "typescript": "6.0.3",
    "vite": "5.4.14"
  }
}
