{
    "rewrites": [
        {
            "source": "/api/farcaster-check",
            "destination": "/api/audit-bundle?action=check"
        },
        {
            "source": "/api/cron/sync-events",
            "destination": "/api/audit-bundle?action=sync"
        },
        {
            "source": "/api/admin/tasks/:action",
            "destination": "/api/admin/tasks-bundle?action=:action"
        },
        {
            "source": "/api/admin/check",
            "destination": "/api/admin/admin-bundle?action=check"
        },
        {
            "source": "/api/admin/sync-tiers",
            "destination": "/api/admin/admin-bundle?action=sync-tiers"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https://*.walletconnect.com https://*.walletconnect.org https://*.coinbase.com; connect-src 'self' https: http: wss: ws: https://*.base.org https://*.alchemy.com https://*.supabase.co https://*.supabase.in;"
                }
            ]
        }
    ]
}