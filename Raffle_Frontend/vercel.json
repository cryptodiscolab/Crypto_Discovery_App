{
    "rewrites": [
        {
            "source": "/api/rpc",
            "destination": "/api/audit-bundle?action=rpc"
        },
        {
            "source": "/api/farcaster-check",
            "destination": "/api/audit-bundle?action=check"
        },
        {
            "source": "/api/farcaster/:action",
            "destination": "/api/user-bundle?action=fc-:action"
        },
        {
            "source": "/api/cron/sync-events",
            "destination": "/api/audit-bundle?action=sync"
        },
        {
            "source": "/api/user/:action",
            "destination": "/api/user-bundle?action=:action"
        },
        {
            "source": "/api/farcaster/sync",
            "destination": "/api/user-bundle?action=fc-sync"
        },
        {
            "source": "/api/tasks/:action",
            "destination": "/api/tasks-bundle?action=:action"
        },
        {
            "source": "/api/verify-action",
            "destination": "/api/tasks-bundle?action=social-verify"
        },
        {
            "source": "/api/admin/tasks/:action",
            "destination": "/api/admin-bundle?action=task-:action"
        },
        {
            "source": "/api/admin/system/update",
            "destination": "/api/admin-bundle"
        },
        {
            "source": "/api/admin/:action",
            "destination": "/api/admin-bundle?action=:action"
        },
        {
            "source": "/api/leaderboard",
            "destination": "/api/user-bundle?action=leaderboard"
        },
        {
            "source": "/api/raffle/:action",
            "destination": "/api/raffle-bundle?action=:action"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://*.walletconnect.com https://*.walletconnect.org https://*.coinbase.com https://vercel.live https://*.vercel.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https: https://fonts.gstatic.com; connect-src 'self' https://*.base.org https://*.basescan.org https://*.alchemy.com https://*.infura.io https://*.supabase.co https://*.supabase.in https://*.vercel.com https://vercel.live https://*.walletconnect.com wss://*.walletconnect.com wss://*.walletconnect.org https://*.walletconnect.org https://*.web3modal.org https://*.web3modal.com https://*.coinbase.com wss://*.coinbase.com https://*.pinata.cloud https://gateway.pinata.cloud https://ipfs.io https://api.dexscreener.com https://api.binance.com https://*.lifi.com https://li.quest https://api.neynar.com https://*.farcaster.xyz https://*.warpcast.com https://cryptologos.cc; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none';"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=31536000; includeSubDomains"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                },
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "same-origin-allow-popups"
                },
                {
                    "key": "Cross-Origin-Embedder-Policy",
                    "value": "unsafe-none"
                },
                {
                    "key": "Cross-Origin-Resource-Policy",
                    "value": "cross-origin"
                }
            ]
        }
    ],
    "crons": [
        {
            "path": "/api/cron/sync-events",
            "schedule": "0 0 * * *"
        },
        {
            "path": "/api/sync-xp-onchain",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/lurah-cron",
            "schedule": "0 1 * * *"
        }
    ]
}