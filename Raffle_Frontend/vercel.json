{
    "rewrites": [
        {
            "source": "/api/rpc",
            "destination": "/api/audit-bundle?action=rpc"
        },
        {
            "source": "/api/farcaster-check",
            "destination": "/api/audit-bundle?action=check"
        },
        {
            "source": "/api/farcaster/check",
            "destination": "/api/audit-bundle?action=check"
        },
        {
            "source": "/api/cron/sync-events",
            "destination": "/api/audit-bundle?action=sync"
        },
        {
            "source": "/api/user/:action",
            "destination": "/api/user-bundle?action=:action"
        },
        {
            "source": "/api/farcaster/sync",
            "destination": "/api/user-bundle?action=fc-sync"
        },
        {
            "source": "/api/tasks/:action",
            "destination": "/api/tasks-bundle?action=:action"
        },
        {
            "source": "/api/verify-action",
            "destination": "/api/tasks-bundle?action=social-verify"
        },
        {
            "source": "/api/admin/tasks/:action",
            "destination": "/api/admin/tasks-bundle?action=:action"
        },
        {
            "source": "/api/admin/:action(check|sync-tiers)",
            "destination": "/api/admin/admin-bundle?action=:action"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https://*.walletconnect.com https://*.walletconnect.org https://*.coinbase.com https://vercel.live https://*.vercel.com; connect-src 'self' https: http: wss: ws: https://*.base.org https://*.alchemy.com https://*.supabase.co https://*.supabase.in https://*.vercel.com https://vercel.live;"
                }
            ]
        }
    ]
}