{
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lurah": "node test-lurah.cjs",
    "gitleaks-check": "gitleaks-secret-scanner",
    "gitleaks-full": "gitleaks-secret-scanner --diff-mode all",
    "gitleaks-history": "gitleaks-secret-scanner --diff-mode history",
    "git-flow:guard": "node scripts/audits/git_flow_guard.cjs",
    "git-flow:ci": "node scripts/audits/git_flow_guard.cjs --ci-pr",
    "test:all": "node scripts/audits/run_required_tests.cjs",
    "compile:contracts": "hardhat compile",
    "size:contracts": "echo 'contract-sizer: use hardhat build output'",
    "predeploy:v16": "node --check hardhat.config.mjs && node --check scripts/deployments/deployV16.cjs && hardhat compile",
    "deploy:v16": "hardhat run scripts/deployments/deployV16.cjs --network base-sepolia",
    "prepare": "husky",
    "orchestron": "node scripts/orchestrator/nexus_orchestrator.cjs",
    "ncc-sentinel": "node scripts/nexus/ncc-sentinel.cjs",
    "ncc-generate": "node scripts/nexus/ncc-generator.cjs",
    "gemini": "gemini",
    "orchestrate-gemini": "node scripts/orchestrator/gemini_agent_bridge.js",
    "lint": "cd Raffle_Frontend && npm run lint"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@nomicfoundation/hardhat-ethers": "^4.0.0",
    "@nomicfoundation/hardhat-mocha": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.0",
    "@openzeppelin/contracts": "5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@openzeppelin/hardhat-upgrades": "^4.0.0",
    "@supabase/mcp-server-supabase": "0.7.0",
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.7",
    "chai": "^5.0.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "gitleaks-secret-scanner": "2.1.1",
    "hardhat": "^3.0.0",
    "husky": "9.0.11",
    "pg": "^8.21.0",
    "typescript": "^5.4.5",
    "zod": "^3.25.0"
  },
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.42.0",
    "telegraf": "4.16.3",
    "viem": "2.52.2"
  },
  "overrides": {
    "ws": "8.21.0",
    "uuid": "11.1.1",
    "undici": "6.26.0",
    "minimatch": "9.0.9",
    "glob": "10.5.0",
    "js-cookie": "3.0.8",
    "lodash": "4.18.1",
    "serialize-javascript": "7.0.5",
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "cookie": "0.7.2"
  }
}